# Smart Teacher — Configuration Template
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env with real secrets!

# === CRITICAL - Must be set ===
OPENAI_API_KEY=sk-your-openai-key-here
POSTGRES_PASSWORD=your-secure-database-password

# === API Keys (Optional) ===
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_teacher
POSTGRES_USER=admin

# === Cache & Vector DB ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=smart_teacher_multimodal

# === LLM Settings ===
GPT_MODEL=gpt-4o-mini
GPT_MAX_TOKENS=400
GPT_TEMPERATURE=0.7
MAX_HISTORY_TURNS=10

# === Speech Recognition ===
STT_BACKEND=faster-whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_THREADS=4

# === Text-to-Speech ===
TTS_PROVIDER=edge
TTS_MODEL=eleven_multilingual_v2
TTS_OUTPUT_FORMAT=mp3_22050_32

# === RAG ===
RAG_ENABLED=false
RAG_NUM_RESULTS=5
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_DB_DIR=data/multimodal_db

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === Paths ===
COURSES_DIR=courses
MEDIA_DIR=media
LOGS_DIR=logs

# === Logging ===
CSV_LOG_FILE=logs/metrics.csv
STT_LOG_FILE=logs/stt_metrics.csv
