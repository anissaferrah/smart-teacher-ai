# =========================
# Smart Teacher - .env
# Copy this file to `.env`
# =========================

# --- API keys ---
OPENAI_API_KEY=sk-your-openai-key
ELEVENLABS_API_KEY=

# --- Core server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_teacher
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
# Optional explicit SQLAlchemy URL
# DATABASE_URL=postgresql+asyncpg://admin:secret@localhost:5432/smart_teacher

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- TTS ---
TTS_PROVIDER=edge
TTS_MODEL=eleven_multilingual_v2
TTS_OUTPUT_FORMAT=mp3_22050_32

# --- Analytics / optional services ---
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=smart_teacher
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

ELASTICSEARCH_HOST=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# --- MinIO / media storage ---
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-teacher
MINIO_SECURE=false
LOCAL_MEDIA_DIR=./media

# --- Jitsi ---
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=
JITSI_APP_SECRET=
JITSI_SELF_HOSTED=false

