"""Smart Teacher — Course Ingestion to Qdrant RAG"""

import argparse
import logging
import os
import sys
import time
from pathlib import Path
from typing import List

from dotenv import load_dotenv

from config import Config
from modules.multimodal_rag import MultiModalRAG

load_dotenv()

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(name)s — %(message)s")
log = logging.getLogger("SmartTeacher.Ingest")

SUPPORTED_EXTENSIONS: set = {".pdf", ".docx", ".pptx", ".txt", ".html", ".md"}


def collect_files(path: str) -> List[str]:
    p = Path(path)
    if not p.exists():
        log.error(f"Path not found: {path}")
        return []

    if p.is_file():
        if p.suffix.lower() in SUPPORTED_EXTENSIONS:
            log.info(f"Found file: {p}")
            return [str(p)]
        else:
            log.warning(f"Unsupported extension: {p.suffix}")
            return []

    files = []
    for ext in SUPPORTED_EXTENSIONS:
        files.extend(p.glob(f"**/*{ext}"))
    
    files_sorted = sorted([str(f) for f in files])
    log.info(f"Found {len(files_sorted)} files in {p}")
    return files_sorted


def print_stats(rag: MultiModalRAG) -> None:
    stats = rag.get_stats()
    
    print("\n" + "=" * 60)
    print("📊 RAG STATISTICS")
    print("=" * 60)
    print(f"  Status        : {'✅ Ready' if stats['is_ready'] else '❌ Not Ready'}")
    print(f"  Total Chunks  : {stats.get('total_docs', 0)}")
    print(f"  Cache Entries : {stats.get('cache_entries', 0)}")
    print(f"  BM25 Index    : {'✅ Ready' if stats.get('bm25_ready') else '❌ Building'}")

    subjects = stats.get("subjects", {})
    if subjects:
        print(f"\n  📚 Subjects:")
        for subject, count in sorted(subjects.items(), key=lambda x: -x[1]):
            print(f"     {subject:25s} → {count} chunks")

    languages = stats.get("languages", {})
    if languages:
        print(f"\n  🌍 Languages:")
        for lang, count in sorted(languages.items(), key=lambda x: -x[1]):
            print(f"     {lang:10s} → {count} chunks")
    
    print("=" * 60 + "\n")


def main() -> int:
    parser = argparse.ArgumentParser(description="Smart Teacher — Index courses")
    parser.add_argument("--file", type=str, help="Single file to index")
    parser.add_argument("--dir", type=str, help="Directory to index (recursive)")
    parser.add_argument("--incremental", action="store_true", help="Add without reset")
    parser.add_argument("--reset", action="store_true", help="Clear collection first")
    parser.add_argument("--stats", action="store_true", help="Show stats only")
    parser.add_argument("--dm", type=str, help="Index DM course directory")
    
    args = parser.parse_args()

    print("=" * 70)
    print("📚 SMART TEACHER — COURSE INGESTION")
    print("=" * 70)

    log.info(f"Initializing RAG (db_dir={Config.RAG_DB_DIR}) with LOCAL embeddings…")
    rag = MultiModalRAG(db_dir=Config.RAG_DB_DIR, force_local_embeddings=True)

    if args.stats:
        print_stats(rag)
        return 0

    files_to_index = []
    
    if args.file:
        files_to_index = collect_files(args.file)
    elif args.dir:
        files_to_index = collect_files(args.dir)
    elif args.dm:
        files_to_index = collect_files(args.dm)
    else:
        default_dir = Path("courses")
        if default_dir.exists():
            files_to_index = collect_files(str(default_dir))
        else:
            log.error("No courses/ directory found")
            return 1

    if not files_to_index:
        log.error("No files to index")
        return 1

    if args.reset:
        log.warning("Resetting collection…")
        rag.reset()

    print(f"\n📖 Indexing {len(files_to_index)} file(s)…\n")
    start_time = time.time()
    
    indexed_count = 0
    for idx, file_path in enumerate(files_to_index, 1):
        try:
            log.info(f"[{idx}/{len(files_to_index)}] Indexing: {file_path}")
            rag.add_documents(file_path)
            indexed_count += 1
        except Exception as exc:
            log.error(f"Failed to index {file_path}: {exc}")
            continue

    duration = time.time() - start_time
    
    print(f"\n" + "=" * 70)
    print(f"✅ Indexing complete!")
    print(f"   Processed: {indexed_count}/{len(files_to_index)} files")
    print(f"   Duration:  {duration:.2f}s")
    print("=" * 70)

    print_stats(rag)

    return 0 if indexed_count > 0 else 1


if __name__ == "__main__":
    sys.exit(main())